# Copy this file to `.env` and fill in your real keys.
# Do NOT commit the real .env file.

# Supabase — create a project at https://supabase.com, then grab these
# from Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Gemini — generate at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key

# Groq (powers the N.I.K.I. chatbot) — https://console.groq.com/keys
VITE_GROQ_API_KEY=your-groq-api-key

# F1 2026 prediction API — FastAPI server that runs the XGBoost
# predictor on demand. Start locally with:
#   cd ml_pipeline && uvicorn api:app --port 8000 --reload
VITE_PREDICTION_API_URL=http://localhost:8000

# ── Supabase SERVICE role key — ONLY for ml_pipeline/run_pipeline.py ──
# This bypasses RLS and lets the offline pipeline upsert predictions.
# Grab it from Project Settings → API → service_role (NEVER ship this
# to the browser; it's used only by Python + GitHub Actions).
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
