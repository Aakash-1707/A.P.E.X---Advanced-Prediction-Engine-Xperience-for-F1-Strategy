# Copy this file to `.env` and fill in your real keys.
# Do NOT commit the real .env file.

# Supabase — create a project at https://supabase.com, then grab these
# from Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# NOTE:
# Gemini and Groq keys should NOT be exposed to the browser anymore.
# Put them in Netlify Site Settings -> Environment Variables instead:
#   GEMINI_API_KEY=...
#   GROQ_API_KEY=...

# F1 2026 prediction API — FastAPI server that runs the XGBoost
# predictor on demand. Start locally with:
#   cd ml_pipeline && uvicorn api:app --port 8000 --reload
VITE_PREDICTION_API_URL=http://localhost:8000

# ── Supabase SERVICE role — ml_pipeline + GitHub Actions only ──
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# GitHub Actions secrets: SUPABASE_URL, SUPABASE_SERVICE_KEY
# Workflows sync_standings.yml and f1_pipeline.yml update championship points.
